{
  "name": "quic-festival",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "audit": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run lint && tsc --noEmit && npm run test:cov",
    "analyze": "ANALYZE=true next build",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "load:rsvp": "k6 run tests/load/rsvp.k6.js",
    "stryker": "stryker run"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.0",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^11.15.0",
    "html5-qrcode": "^2.3.8",
    "next": "16.2.4",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.74.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.1.1",
    "@stryker-mutator/vitest-runner": "^9.1.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "msw": "^2.13.6",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
