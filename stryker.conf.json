{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_": "Mutation testing — corre só em src/lib/** (puro, sem React). Inicialmente desligado em CI; correr manualmente: `npx stryker run`.",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/lib/validators.ts",
    "src/lib/csv.ts",
    "src/lib/ics.ts",
    "src/lib/rate-limit.ts",
    "src/lib/audit.ts",
    "src/lib/turnstile.ts",
    "src/lib/qr-token.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 30000,
  "concurrency": 4
}
