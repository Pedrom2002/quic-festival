NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM="QUIC Festival <onboarding@resend.dev>"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional rate-limit backend (Upstash Redis REST). Without these → memory fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Captcha (Cloudflare Turnstile). Required in production.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Kill-switch. Set to "false" to disable /api/rsvp (returns 503).
# RSVP_OPEN=false
