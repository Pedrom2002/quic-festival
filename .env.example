NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM="QUIC Festival <onboarding@resend.dev>"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional rate-limit backend (Upstash Redis REST). Without these → memory fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Captcha (Cloudflare Turnstile). Required in production.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Kill-switch. Set to "false" to disable /api/rsvp (returns 503).
# RSVP_OPEN=false

# Sentry (opcional mas FORTEMENTE recomendado em produção). Sem DSN → init no-op.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# QR token signing secret. >= 32 bytes random. Roda anualmente ou após incidente.
# Sem secret → tokens caem no modo legacy (UUID puro). Em produção tem de estar definido.
QR_TOKEN_SECRET=
# Janela de validade do token assinado (ms). Default: ~6 meses.
QR_TOKEN_TTL_MS=

# Cron secret partilhado entre Vercel Cron e o endpoint de retries. >= 32 bytes random.
CRON_SECRET=
